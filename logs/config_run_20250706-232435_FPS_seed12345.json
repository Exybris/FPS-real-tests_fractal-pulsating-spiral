      "phi": 3.14,
      "alpha": 0.08,
      "beta": 0.45,
      "k": 0.9,
      "x0": 0.45
    }
  ],
  "coupling": {
    "type": "spiral",
    "c": 0.25,
    "closed": false,
    "mirror": false
  },
  "latence": {
    "gamma_mode": "adaptive_aware",
    "gamma_dynamic": {
      "enable_spacing": true,
      "enable_G_awareness": true,
      "discovery_logging": true
    }
  },
  "regulation": {
    "feedback_mode": "archetype",
    "G_arch": "adaptive_aware",
    "lambda": 1.0,
    "alpha": 1.0,
    "beta": 2.0,
    "dynamic_G": true,
    "enable_G_gamma_coupling": true
  },
  "enveloppe": {
    "env_mode": "static",
    "sigma_n_static": 0.1,
    "mu_n": 0.0
  },
  "spiral": {
    "phi": 1.618,
    "epsilon": 0.05,
    "omega": 0.1,
    "theta": 0.0
  },
  "dynamic_parameters": {
    "dynamic_beta": false,
    "dynamic_phi": false
  },
  "exploration": {
    "metrics": [
      "S(t)",
      "C(t)",
      "effort(t)"
    ],
    "window_sizes": [
      10,
      50
    ],
    "fractal_threshold": 0.8,
    "detect_fractal_patterns": false,
    "detect_anomalies": false,
    "detect_harmonics": false,
    "anomaly_threshold": 3.0,
    "min_duration": 3
  },
  "to_calibrate": {
    "variance_d2S": 175.0,
    "fluidity_threshold": 0.5,
    "stability_ratio": 10.0,
    "resilience": 1.0,
    "entropy_S": 0.5,
    "mean_high_effort": 2.0,
    "d_effort_dt": 1.0,
    "t_retour": 5.0,
    "gamma_n": 1.0,
    "env_n": "gaussienne",
    "sigma_n": 0.1,
    "cpu_step_ctrl": 1.5,
    "max_chaos_events": 5,
    "effort_transitoire_threshold": 2.0,
    "effort_chronique_threshold": 1.5
  },
  "validation": {
    "criteria": [
      "fluidity",
      "stability",
      "resilience"
    ],
    "thresholds": {
      "cpu_step": 0.01,
      "effort": 10.0,
      "mean_abs_error": 1.0,
      "entropy_S": 0.1,
      "max_median_ratio": 100.0
    },
    "alert_sigma": 3,
    "batch_size": 5,
    "refine_after_runs": false,
    "auto_log_refinement": false
  },
  "analysis": {
    "compare_kuramoto": false,
    "save_indiv_files": false,
    "export_html_report": false,
    "visualize_grid": false
  },
  "debug": {
    "log_detailed": false,
    "log_alignments": true,
    "save_discoveries": true
  }
}